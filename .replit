run = "pnpm run dev"
entrypoint = "app/page.tsx"
modules = ["nodejs-24"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "pnpm install && pnpm run build"]
run = ["sh", "-c", "HOSTNAME=0.0.0.0 node .next/standalone/server.js"]

[agent]
expertMode = true

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080
